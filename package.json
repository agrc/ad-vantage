{
  "name": "ad-vantage",
  "version": "1.3.11",
  "description": "Chrome extension to enhance the Vantage timesheet app",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc -b",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest --run",
    "preview": "vite preview",
    "chrome:dev": "open -na \"Google Chrome Dev\" --args --remote-debugging-port=9223 --user-data-dir=\"$HOME/.ad-vantage-chrome-dev\""
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.2.2",
    "@ugrc/eslint-config": "^1.3.0",
    "eslint": "^10.4.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
