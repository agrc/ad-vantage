{
  "manifest_version": 3,
  "name": "ad-vantage",
  "version": "1.3.10",
  "description": "Work faster in Vantage with a clearer timesheet, smarter entry tools, and helpful error checks.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://utahdev.servicenowservices.com/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup/index.html",
    "default_title": "ad-vantage"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vantage.utah.gov/*",
        "https://vantage.access.utah.gov/*"
      ],
      "js": ["src/content/index.ts"]
    }
  ]
}
